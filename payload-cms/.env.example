# Postgres connection (Neon, Supabase, Railway, etc.)
DATABASE_URI=postgresql://user:password@host:5432/dbname

# Secret used to sign auth tokens — generate with: openssl rand -base64 32
PAYLOAD_SECRET=replace-me-with-a-long-random-string

# Public URL where Payload is deployed (no trailing slash)
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# CORS origins allowed to read content (your frontend URL)
PAYLOAD_PUBLIC_FRONTEND_URL=http://localhost:5173
